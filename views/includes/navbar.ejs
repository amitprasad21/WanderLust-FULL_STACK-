<style>
  .search-btn{
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
    white-space: nowrap;
  }
  .search-btn:hover{
    background-color: #d6363f;
    color: #fff;
  }

  .search-btn i {
    display: inline;
    margin-right: 0.5rem;
  }

  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 1.5rem;
    font-size: 0.9rem;
    min-width: 200px;
  }

  @media (max-width: 991px) {
    .search-inp {
      min-width: 150px;
      padding: 0.5rem 1rem;
    }
    
    .search-btn {
      padding: 0 0.75rem;
      font-size: 0.9rem;
    }
    
    .search-btn i {
      margin-right: 0.25rem;
    }
  }

  @media (max-width: 576px) {
    .search-inp {
      min-width: 120px;
      font-size: 0.85rem;
    }
    
    .navbar-nav.ms-auto {
      margin-top: 10px;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/listing"><i class="fa-solid fa-compass"></i><span>WanderLust</span></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link" href="/listing">Explore</a>
          
        </div>
        <div class="navbar-nav ms-auto">
          <form class="d-flex" role="search" action="/listing" method="GET">
            <input class="form-control me-2 search-inp" type="search" name="search" placeholder="Search destinations" value="<%= typeof currentFilters !== 'undefined' && currentFilters.search ? currentFilters.search : '' %>" />
            <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
          </form>
        </div>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="listing/new">Airbnb your home</a>

          <% if (!currUser) { %>
            <a class="nav-link" href="/signup"><b>Sign up</b></a>
            <a class="nav-link" href="/login"><b>Log in</b></a>
          <% } %>
          <% if (currUser) { %>
            <a class="nav-link" href="/logout"><b>Log Out</b></a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>